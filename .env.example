# Copy this file to .env and adjust values.
# The scripts auto-load .env by default.

# Target router WiFi
TARGET_SSID=meinRouter
TARGET_PSW=CHANGE_ME

# AP passwords per AC module
AP_PSW_C6982A76=12345678
AP_PSW_C699E6BF=12345678
AP_PSW_C699E72B=12345678

# Timing
CHECK_INTERVAL=60
INITIAL_SEND_WAIT=5
SEND_RETRIES=12
SEND_INTERVAL=2
VERIFY_TIMEOUT=120
VERIFY_SCAN_INTERVAL=5
CONNECT_TIMEOUT=60

# AP IP fallback list (space separated)
AP_IP_CANDIDATES="192.168.1.1 192.168.0.1"

# Optional fixed interface for Pi variant
# WLAN_IFACE=wlan0
